{
  "name": "safelink",
  "version": "1.0.0",
  "description": "SafeLink – AI-Powered Intelligent Safety Layer for Mobility & Delivery",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "npx nodemon server.js",
    "migrate": "npx prisma migrate dev --name init",
    "migrate:prod": "npx prisma migrate deploy",
    "seed": "node prisma/seed.js",
    "generate": "npx prisma generate",
    "studio": "npx prisma studio",
    "setup": "npm install && npx prisma generate && npx prisma migrate dev --name init && node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "prisma": "^6.4.1",
    "nodemon": "^3.1.9"
  }
}
